{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "python3 -m pip install --break-system-packages -r requirements.txt",
  "buildCommand": "python3 scripts/build_static.py",
  "outputDirectory": "public",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/docs", "destination": "/api/index" },
    { "source": "/redoc", "destination": "/api/index" },
    { "source": "/openapi.json", "destination": "/api/index" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/pipeline", "destination": "/pipeline.html" },
    { "source": "/kafka", "destination": "/kafka.html" },
    { "source": "/docker", "destination": "/docker.html" },
    { "source": "/ingestion", "destination": "/ingestion.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/attendance", "destination": "/attendance.html" },
    { "source": "/checkin", "destination": "/checkin.html" },
    { "source": "/school", "destination": "/school.html" },
    { "source": "/payments", "destination": "/payments.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/inventory", "destination": "/inventory.html" },
    { "source": "/trainers", "destination": "/trainers.html" },
    { "source": "/ceo", "destination": "/ceo.html" },
    { "source": "/notifications", "destination": "/notifications.html" }
  ]
}
